{
  "name": "kpa-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "OBENA Key Points Analysis — TypeScript MVP",
  "type": "module",
  "scripts": {
    "kpa": "tsx src/cli.ts",
    "start": "tsx src/server.ts",
    "dev:api": "tsx --watch src/server.ts",
    "dev:web": "pnpm -C web dev",
    "build:web": "pnpm -C web build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write src",
    "format:md": "markdownlint-cli2 --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.14.0",
    "@mendable/firecrawl-js": "^1.27.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "hono": "^4.7.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "unfluff": "^3.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,mts,cts,json,jsonc,yaml,yml}": "prettier --write",
    "*.md": "markdownlint-cli2 --fix",
    "*.{ts,js,mts,mjs,cts,cjs}": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "svelte-preprocess"
    ]
  }
}
