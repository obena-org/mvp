# OBENA Local Machine Overrides (Optional)
# Copy this file to config/.env.local and customize for your local machine

# =============================================================================
# Server Configuration Overrides  
# =============================================================================

# Number of Hypercorn workers for production server (default: 4)
# Only affects production mode - development uses single uvicorn process
# HYPERCORN_WORKERS=4

# =============================================================================
# Pipeline Worker Configuration
# =============================================================================

# Whether to launch GPU worker when running pipeline (default: true)
# Requires CUDA-capable GPU and CUDA toolkit installation  
# USE_CUDA_GPU=true

# Whether to launch Playwright worker when running pipeline (default: true)
# Requires Chrome/Chromium installation for browser automation
# USE_PLAYWRIGHT=true

# =============================================================================
# Concurrency Limits (Semaphore-based)
# =============================================================================

# Maximum concurrent Playwright browser instances (default: 10)
# PLAYWRIGHT_MAX_CONCURRENT_INSTANCES=10

# Maximum concurrent HTTPx requests across all workers (default: 20)
# AUTOFETCH_MAX_CONCURRENT_REQUESTS=20

# =============================================================================
# Browser Window Positioning (Development)
# =============================================================================

# Playwright browser window position (useful for multi-monitor setups)
# BROWSER_WINDOW_X=10
# BROWSER_WINDOW_Y=10

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# Crawling rate limits (requests per second per host)
# CRAWL_RPS_LIMIT=2.0
# CRAWL_BURST_LIMIT=4

# Playwright rate limits (requests per second per host) 
# PLAYWRIGHT_RPS_LIMIT=0.5
# PLAYWRIGHT_BURST_LIMIT=2

# =============================================================================
# Pipeline Configuration
# =============================================================================

# Default pipeline processing window for smoke tests (days)
# DEFAULT_PIPELINE_DAYS=3

# =============================================================================
# Development Tools
# =============================================================================

# Frontend local host and port override
# FRONTEND_LOCAL_HOSTPORT=localhost:5173

# Vite telemetry (disable for privacy)
# VITE_ENABLE_TELEMETRY=false

# =============================================================================
# Tor installation locations
# =============================================================================

# TOR_EXE=C:/Tor/tor/tor.exe
# TOR_RC=C:/Tor/tor/torrc
# TOR_DATA_DIR=C:/Tor/data
